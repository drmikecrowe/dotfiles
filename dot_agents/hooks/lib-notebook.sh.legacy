#!/usr/bin/env bash
# ~/.agents/hooks/lib-notebook.sh — continuity-notebook shared helpers
#
# The "lab notebook" model: each session gets a folder of append-only,
# immutable chunks. User intent is captured verbatim (never summarized);
# the work narrative is summarized into dated logbook entries by a detached
# Haiku pass. At compaction / resume the brief is assembled and injected.
#
# Layout:
#   ~/.agents/runtime/notebook/<slug>/<session_id>/
#     intent.md        append-only VERBATIM user prompts (code pastes trimmed)
#     notes/NNNN.md    immutable logbook chunks (one per summarizer pass)
#     brief.md         (optional) last assembled brief, for debugging
#     .turns           tick counter (Stop-driven threshold)
#     .lastline        transcript line offset already summarized
#     .last-inject     mtime marker to dedupe double injection
#
# Sourced by hook scripts AND by bin/{extract,summarize}-thread.sh.
# Defines functions only; no side effects on source.

# Context sentinels. run-hook.sh forwards ONLY the text between these to the
# LLM for context events; everything else a .d/ script prints stays swallowed
# (logged). Plain ASCII so agentmemory log noise never collides.
NB_CTX_BEGIN='<<<NB_CTX_BEGIN>>>'
NB_CTX_END='<<<NB_CTX_END>>>'

nb_root() { printf '%s' "$HOME/.agents/runtime/notebook"; }

# Slug from a working-dir path: /a/b → a-b (matches Claude project-dir format).
nb_slug() {
    local cwd="${1:-}"
    if [ -z "$cwd" ]; then printf '_'; return; fi
    printf '%s' "$cwd" | sed 's#/#-#g; s/^-//'
}

# Echo the session notebook dir (does NOT create it — callers that write mkdir).
nb_session_dir() {
    local sid="${1:-}" cwd="${2:-}"
    [ -n "$sid" ] || return 1
    printf '%s/%s/%s' "$(nb_root)" "$(nb_slug "$cwd")" "$sid"
}

# Extract a field from a JSON payload. Empty string on any failure.
nb_json() {
    local payload="$1" path="$2"
    printf '%s' "$payload" | jq -r "$path // empty" 2>/dev/null || true
}

# Trim a long blob to head+tail with an elision marker (code-paste guard).
nb_trim() {
    local s="$1" max="${2:-1500}"
    if [ "${#s}" -le "$max" ]; then
        printf '%s' "$s"
    else
        printf '%s\n…[%s chars elided]…\n%s' "${s:0:1100}" "$(( ${#s} - 1400 ))" "${s: -300}"
    fi
}

# Spawn the summarizer fully detached so it never blocks the turn.
nb_spawn_summarizer() {
    local dir="$1" transcript="$2"
    local bin="$HOME/.agents/bin/summarize-thread.sh"
    [ -x "$bin" ] || return 0
    [ -n "$transcript" ] && [ -f "$transcript" ] || return 0
    setsid bash -c '"$0" --session-dir "$1" --transcript "$2"' \
        "$bin" "$dir" "$transcript" </dev/null >/dev/null 2>&1 &
    disown 2>/dev/null || true
}

# Assemble + emit the recovery brief between sentinels. No-op (return 0) when
# the session has no captured content. Dedupes if called twice within 6s
# (covers a SessionStart + PostCompact double-fire on the same recovery).
nb_emit_brief() {
    local dir="$1"
    [ -d "$dir" ] || return 0

    local intent="$dir/intent.md" notesdir="$dir/notes"
    local has=0
    [ -s "$intent" ] && has=1
    [ -d "$notesdir" ] && [ -n "$(ls -A "$notesdir" 2>/dev/null)" ] && has=1
    [ "$has" -eq 1 ] || return 0

    local marker="$dir/.last-inject"
    if [ -f "$marker" ]; then
        local age=$(( $(date +%s) - $(stat -c %Y "$marker" 2>/dev/null || echo 0) ))
        [ "$age" -lt 6 ] && return 0
    fi
    touch "$marker" 2>/dev/null || true

    {
        printf '%s\n' "$NB_CTX_BEGIN"
        printf '# Recovery Brief — continuity notebook\n'
        printf '_User intent below is verbatim. The logbook is a summarized record built during the session._\n\n'

        if [ -s "$intent" ]; then
            printf '## User Intent (verbatim, chronological)\n\n'
            cat "$intent"
            printf '\n'
        fi

        if [ -d "$notesdir" ]; then
            local files
            mapfile -t files < <(ls -1 "$notesdir"/*.md 2>/dev/null | sort | tail -12)
            if [ "${#files[@]}" -gt 0 ]; then
                printf '\n## Engineering Logbook (latest %s entries)\n\n' "${#files[@]}"
                cat "${files[@]}"
            fi
        fi

        printf '\n%s\n' "$NB_CTX_END"
    } | tee "$dir/brief.md"
}
