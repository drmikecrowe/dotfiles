#!/bin/bash
# PreToolUse: block Grep/Glob/Read/Search on source until Serena or agentmemory MCP called.
# Unlock: mcp__serena__* OR mcp__agentmemory__* sets the marker.
set -euo pipefail
# shellcheck source=/dev/null
source "$(dirname "$0")/lib-log.sh"

INPUT=$(cat)
TOOL=$(jq -r '.tool_name // empty' <<< "$INPUT")
MARKER=/tmp/nav-mcp-used-$PPID
UNLOCK=/tmp/nav-unlock-$PPID

log_setup "code-nav-gate"

if [ -f "$UNLOCK" ]; then
  log_op "ALLOWED session unlock: $TOOL"
  exit 0
fi

# Clean stale markers daily
find /tmp -maxdepth 1 -name 'nav-*' -mtime +1 -delete 2>/dev/null || true

case "$TOOL" in
  Grep|Glob|Read|Search) ;;
  *) exit 0 ;;
esac

# Extract path/pattern from whichever field is present
FP=$(jq -r '.tool_input.file_path // .tool_input.path // .tool_input.pattern // .tool_input.glob // ""' <<< "$INPUT")

# Pass through non-code files and system/config paths
if [[ "$FP" =~ \.(md|json|yaml|yml|toml|lock|txt|env|sh|cfg|conf|ini|example)$ ]] \
  || [[ "$FP" =~ (\.claude|\.gsd|\.pi|\.serena|\.agents|CLAUDE\.md|AGENTS\.md|hooks/|commands/|rules/|/tmp/|/var/|settings|Desktop) ]]; then
  log_op "ALLOWED passthrough non-code: $TOOL $FP"
  exit 0
fi

# Pass through if MCP was called within last 120s
if [ -f "$MARKER" ]; then
  MTIME=$(stat -c %Y "$MARKER" 2>/dev/null || echo 0)
  AGE=$(( $(date +%s) - MTIME ))
  if [ "$AGE" -lt 120 ]; then
    log_op "ALLOWED MCP marker fresh (${AGE}s): $TOOL $FP"
    exit 0
  fi
fi

log_op "BLOCKED $TOOL: $FP"
cat >&2 << EOF
BLOCKED: $TOOL on source file requires MCP call first.

  Exploration (what/where/how):  Serena → search_graph / find_symbol / get_symbols_overview
  Session memory / decisions:    agentmemory → memory_smart_search

Either MCP call unlocks Read/Grep for 120s.
Override (this session): touch $UNLOCK
EOF
exit 2
