#!/bin/bash
# PostToolUse: touch marker when CBM or Serena MCP fires (unlocks code-nav-gate 120s).
set -euo pipefail
# shellcheck source=/dev/null
source "$(dirname "$0")/lib-log.sh"

INPUT=$(cat)
TOOL=$(jq -r '.tool_name // empty' <<< "$INPUT")

if [[ "$TOOL" == mcp__serena__* ]] || [[ "$TOOL" == mcp__agentmemory__* ]]; then
  log_setup "code-nav-marker"
  touch /tmp/nav-mcp-used-$PPID
  log_op "MCP unlock: $TOOL → /tmp/nav-mcp-used-$PPID"
fi

exit 0
