{
  "allowedTools": [
    "mcp__codebase-memory-mcp__*",
    "mcp__context-mode__*"
  ],
  "editorMode": "vim",
  "effortLevel": "medium",
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "MAX_MCP_OUTPUT_TOKENS": "10000"
  },
  "hasCompletedClaudeInChromeOnboarding": false,
  "hooks": {
    "ElicitationResult": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf running > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf waiting > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|elicitation_dialog"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf running > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf idle > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf running > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "mcpServers": {},
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(dolt add:*)",
      "Bash(dolt branch:*)",
      "Bash(dolt checkout:*)",
      "Bash(dolt commit:*)",
      "Bash(dolt diff:*)",
      "Bash(dolt fetch:*)",
      "Bash(dolt log:*)",
      "Bash(dolt merge:*)",
      "Bash(dolt schema:*)",
      "Bash(dolt sql:*)",
      "Bash(dolt status:*)",
      "Bash(dolt table:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(export:*)",
      "Bash(fd:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git shortlog:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(go:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm build:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(playwriter:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test:*)",
      "Bash(printf:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(source:*)",
      "Bash(tail:*)",
      "Bash(touch:*)",
      "Bash(type:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(wget:*)",
      "Bash(which:*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Read(*)",
      "Write(*)"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset:*)",
      "Bash(git revert:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(git filter-branch:*)",
      "Bash(git reflog:*)",
      "Bash(dolt push:*)",
      "Bash(dolt reset:*)",
      "Bash(dolt revert:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod 777:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)"
    ]
  },
  "preferredNotifChannel": "notifications_disabled",
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "/home/mcrowe/.local/share/mise/shims/ccstatusline",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "tui": "fullscreen",
  "voiceEnabled": true
}