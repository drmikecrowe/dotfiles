{
  "collapseChangelog": true,
  "compaction": {
    "enabled": true
  },
  "defaultModel": "claude-sonnet-4-6",
  "defaultProvider": "claude-code",
  "defaultThinkingLevel": "low",
  "editMode": "hashline",
  "hideThinkingBlock": false,
  "hooks": {
    "PostCompact": [
      {
        "command": "/home/mcrowe/.agents/hooks/serena-activate.sh",
        "timeout": 10000
      }
    ],
    "PostToolUse": [
      {
        "command": "/home/mcrowe/.agents/hooks/code-nav-marker",
        "timeout": 5000
      }
    ],
    "PreCompact": [],
    "PreMilestone": [
      {
        "blocking": true,
        "command": "/home/mcrowe/.config/hooks/clean-baseline-check.sh",
        "timeout": 10000
      }
    ],
    "PreToolUse": [
      {
        "blocking": true,
        "command": "/home/mcrowe/.agents/hooks/bash-ban-raw-tools",
        "match": {
          "tool": "bash"
        },
        "timeout": 10000
      },
      {
        "blocking": true,
        "command": "/home/mcrowe/.agents/hooks/code-nav-gate",
        "match": {
          "tool": [
            "Read",
            "Grep",
            "Glob",
            "Search"
          ]
        },
        "timeout": 10000
      }
    ],
    "SessionStart": [
      {
        "command": "node /home/mcrowe/.local/share/mise/installs/node/22/lib/node_modules/context-mode/hooks/sessionstart.mjs",
        "timeout": 10000
      },
      {
        "command": "/home/mcrowe/.agents/hooks/serena-activate.sh",
        "timeout": 10000
      },
      {
        "command": "/home/mcrowe/.agents/scripts/agent-startup.sh",
        "timeout": 10000
      },
      {
        "command": "/home/mcrowe/.agents/hooks/code-nav-reminder",
        "timeout": 5000
      }
    ],
    "Stop": [
      {
        "_probe": true,
        "command": "/home/mcrowe/.agents/hooks/probes/inspect-payload.sh",
        "timeout": 10000
      }
    ]
  },
  "lastChangelogVersion": "2.78.0",
  "quietStartup": true,
  "steeringMode": "one-at-a-time",
  "theme": "vivid",
  "transport": "sse"
}